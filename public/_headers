# Headers para Netlify/Cloudflare Pages
# Optimiza el tiempo de vida de caché para mejorar el rendimiento

# Archivos estáticos - Caché por 1 año (tienen hash en el nombre)
/static/*
  Cache-Control: public, max-age=31536000, immutable

# JavaScript y CSS con hash - Caché por 1 año
/*.js
  Cache-Control: public, max-age=31536000, immutable
/*.css
  Cache-Control: public, max-age=31536000, immutable

# Imágenes con hash - Caché por 1 año
/static/media/*
  Cache-Control: public, max-age=31536000, immutable

# Fuentes - Caché por 1 año
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Imágenes en public - Caché por 1 mes
/images/*
  Cache-Control: public, max-age=2592000

# PDFs - Caché por 1 semana
/*.pdf
  Cache-Control: public, max-age=604800

# HTML - Caché corto (1 hora) para permitir actualizaciones rápidas
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

# index.html - Sin caché (siempre actualizado)
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Service Worker - Sin caché
/service-worker.js
  Cache-Control: public, max-age=0, must-revalidate

# Manifest
/manifest.json
  Cache-Control: public, max-age=86400

# Habilitar compresión
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
